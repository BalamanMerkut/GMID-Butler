# ─── Discord & AI ─────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
GEMINI_KEY=your_gemini_api_key_here

# ─── Channel to Auto-Clean ────────────────────────────────────────────────────
# Right-click the bot-commands channel in Discord → Copy ID
BOT_COMMANDS_CHANNEL_ID=1234567890123456789

# Hour to run the daily cleanup (UTC, 0-23)
# Example: for 03:00 Turkey time (UTC+3), set this to 0
CLEANUP_HOUR=0

# How many hours before a !priv channel is auto-deleted (default: 12)
PRIV_CHANNEL_LIFETIME_HOURS=12
